{
  "name": "laundry-buddy",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "EXPO_PUBLIC_START_AT_INTRO=true expo start --go",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "generate-assets": "node scripts/generate-assets.mjs",
    "sync-app-icons": "node scripts/sync-app-icons.mjs",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:preview": "eas build --profile preview --platform android",
    "build:preview:all": "eas build --profile preview --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:ios-simulator": "eas build --profile preview-ios-simulator --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:android:apk:local": "bash scripts/build-android-local.sh apk",
    "build:android:aab:local": "bash scripts/build-android-local.sh aab",
    "build:android:local": "bash scripts/build-android-local.sh both",
    "upload:app-public": "node scripts/upload-app-public.mjs"
  },
  "dependencies": {
    "@maplibre/maplibre-react-native": "10.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.109.0",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
